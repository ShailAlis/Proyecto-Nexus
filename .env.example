# ============================================================
# NEXUS — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA comitas el .env real al repositorio.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=change_me_strong_password

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_32char_encryption_key_here
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Discord Bot ---
DISCORD_BOT_TOKEN=...
DISCORD_GUILD_ID=...
DISCORD_APPROVAL_CHANNEL_ID=...

# --- Jira ---
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=NEXUS

# --- Agentes (URLs internas) ---
ANALYST_AGENT_URL=http://localhost:8001
DEVELOPER_AGENT_URL=http://localhost:8002
DESIGNER_AGENT_URL=http://localhost:8003
REVIEWER_AGENT_URL=http://localhost:8004

# --- General ---
TIMEZONE=Europe/Madrid
ENVIRONMENT=development
LOG_LEVEL=INFO