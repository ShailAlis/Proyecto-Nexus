# ============================================================
# NEXUS — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA comitas el .env real al repositorio.
# ============================================================

# --- LLMs ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Jira ---
JIRA_URL=https://tu-dominio.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_TOKEN=...
JIRA_PROJECT_KEY=PN

# --- Discord ---
DISCORD_BOT_TOKEN=...
DISCORD_APPROVAL_CHANNEL_ID=...
DISCORD_NOTIFICATIONS_CHANNEL_ID=...
DISCORD_ERRORS_CHANNEL_ID=...
DISCORD_REQUESTS_CHANNEL_ID=...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- GitHub ---
GIT_TOKEN=ghp_...
GIT_REPO=usuario/nexus

# --- PostgreSQL ---
POSTGRES_DB=nexus
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=...

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- URLs internas ---
DATABASE_URL=postgresql://nexus_user:password@postgres:5432/nexus
# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=...
N8N_WEBHOOK_URL=http://n8n:5678/webhook/nexus-callback
N8N_WEBHOOK_URL_REQUESTS=http://n8n:5678/webhook/nexus-new-request

# --- General ---
ENVIRONMENT=development
